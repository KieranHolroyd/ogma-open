{
  "name": "@thothsupport/open",
  "private": true,
  "description": "Open-source SDK and demos for Thoth agentic tools",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm --filter @thothsupport/webhook test",
    "webhook:build": "pnpm --filter @thothsupport/webhook build",
    "webhook:test": "pnpm --filter @thothsupport/webhook test",
    "demo:dev": "pnpm --filter @thothsupport/demo-agentic-tools-server dev",
    "demo:build": "pnpm webhook:build && pnpm --filter @thothsupport/demo-agentic-tools-server build",
    "demo:start": "pnpm --filter @thothsupport/demo-agentic-tools-server start"
  },
  "devDependencies": {
    "typescript": "7.0.1-rc"
  }
}
